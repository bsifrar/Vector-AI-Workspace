# Workspace runtime defaults for Synapse-connected mode.
# Copy to .env.workspace and adjust as needed.
WORKSPACE_ADAPTER_MODE=external
WORKSPACE_EXTERNAL_BASE_URL=http://127.0.0.1:8080
WORKSPACE_HOST=127.0.0.1
WORKSPACE_PORT=8091
WORKSPACE_MODEL=gpt-5.4
WORKSPACE_DAILY_CAP=20
WORKSPACE_HOURLY_CAP=30
WORKSPACE_INPUT_PRICE=2.5
WORKSPACE_OUTPUT_PRICE=15
# Optional: override local storage path
# WORKSPACE_STORAGE_PATH=workspace_ai/storage/workspace.db
